
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  EMPLOYEE
  MANAGER
  TRANSPORT_ADMIN
  ACCOMMODATION_ADMIN
  DRIVER
  FINANCE_OFFICER
  SECURITY_OFFICER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum VehicleType {
  BUS
  VAN
  CAR
  COASTER
  HIACE
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum OwnershipType {
  OWNED
  VENDOR
}

enum FitnessStatus {
  VALID
  EXPIRED
  PENDING
}

enum DriverStatus {
  AVAILABLE
  ASSIGNED
  INACTIVE
}

enum RouteStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ShiftType {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
  GENERAL
}

enum ShuttleBookingStatus {
  PENDING
  ASSIGNED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum TripStatus {
  CHECKLIST_PENDING
  READY
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripIssueType {
  DELAY
  BREAKDOWN
  SOS
  OTHER
}

enum TravelType {
  INTER_CAMPUS
  WITHIN_CITY
  INTER_CITY
  INTERNATIONAL
}

enum TravelRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum TravelUrgency {
  NORMAL
  URGENT
  EMERGENCY
}

enum RoomType {
  SINGLE
  DOUBLE
  SHARED
  DORMITORY
  GUEST_HOUSE
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  INACTIVE
}

enum AccommodationType {
  INTERNAL_GUEST_HOUSE
  EXTERNAL_HOTEL
}

enum ReservationStatus {
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum ExpenseCategory {
  TRAVEL
  MEAL
  ACCOMMODATION
  FUEL
  OTHER
}

enum ExpenseClaimStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
  CANCELLED
}

enum ExpenseAnomalyStatus {
  NORMAL
  ANOMALY_REVIEW_REQUIRED
}

enum PayrollSyncStatus {
  NOT_READY
  READY_FOR_EXPORT
  EXPORTED
}

enum AuditAction {
  LOGIN
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  CANCEL
  ASSIGN
  CHECK_IN
  CHECK_OUT
  EXPORT
  FLAG
  START_TRIP
  END_TRIP
  REPORT_ISSUE
  SYSTEM
}

enum AuditEntity {
  AUTH
  USER
  VEHICLE
  DRIVER
  ROUTE
  SMART_STOP
  SHUTTLE_BOOKING
  TRAVEL_REQUEST
  ROOM
  ROOM_RESERVATION
  EXPENSE_CLAIM
  TRANSPORT_TRIP
  REPORT
  VENDOR
  TELEMETRY
  SYSTEM
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum VendorContractType {
  MONTHLY
  PER_TRIP
  PER_KM
  ON_DEMAND
}

enum VendorBillStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum TelemetryStatus {
  MOVING
  STOPPED
  DELAYED
  BREAKDOWN
  SOS
  OFFLINE
}

enum TelemetrySource {
  MOBILE_GPS
  MOCK_GPS
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           String     @id @default(uuid())
  fullName     String
  email        String     @unique
  password     String
  phone        String?
  status       UserStatus @default(ACTIVE)

  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])

  driverProfile Driver?
  shuttleBookings ShuttleBooking[]

  travelRequests TravelRequest[] @relation("EmployeeTravelRequests")
  approvedTravelRequests TravelRequest[] @relation("TravelRequestApprovals")

  roomReservations RoomReservation[] @relation("EmployeeRoomReservations")

  expenseClaims ExpenseClaim[] @relation("EmployeeExpenseClaims")
  reviewedExpenseClaims ExpenseClaim[] @relation("FinanceReviewedExpenseClaims")

  auditLogs AuditLog[] @relation("UserAuditLogs")

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Vehicle {
  id            String        @id @default(uuid())
  vehicleNumber String       @unique
  vehicleType   VehicleType
  capacity      Int
  ownershipType OwnershipType @default(OWNED)
  vendorName    String?
  status        VehicleStatus @default(ACTIVE)
  fitnessStatus FitnessStatus @default(PENDING)
  notes         String?

  drivers Driver[]
  transportRoutes TransportRoute[]

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  telemetryLogs VehicleTelemetryLog[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Driver {
  id            String       @id @default(uuid())

  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id])

  licenseNumber String       @unique
  cnic          String?
  address       String?
  status        DriverStatus @default(AVAILABLE)

  vehicleId     String?
  vehicle       Vehicle?     @relation(fields: [vehicleId], references: [id])

  transportRoutes TransportRoute[]
  trips TransportTrip[]

  telemetryLogs VehicleTelemetryLog[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model TransportRoute {
  id             String       @id @default(uuid())

  routeName      String
  routeCode      String       @unique
  shiftType      ShiftType
  routeDate      DateTime?
  startTime      String?
  endTime        String?
  startLocation  String?
  endLocation    String?

  vehicleId      String?
  vehicle        Vehicle?     @relation(fields: [vehicleId], references: [id])

  driverId       String?
  driver         Driver?      @relation(fields: [driverId], references: [id])

  status         RouteStatus  @default(DRAFT)
  notes          String?

  smartStops     SmartStop[]
  shuttleBookings ShuttleBooking[]
  trips TransportTrip[]

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  vendorBills VendorBill[]

  telemetryLogs VehicleTelemetryLog[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SmartStop {
  id             String         @id @default(uuid())

  routeId        String
  route          TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  stopName       String
  stopOrder      Int
  latitude       Float?
  longitude      Float?
  estimatedTime  String?

  shuttleBookings ShuttleBooking[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([routeId, stopOrder])
}

model ShuttleBooking {
  id             String               @id @default(uuid())

  employeeId     String
  employee       User                 @relation(fields: [employeeId], references: [id])

  routeId        String?
  route          TransportRoute?      @relation(fields: [routeId], references: [id])

  pickupStopId   String?
  pickupStop     SmartStop?           @relation(fields: [pickupStopId], references: [id])

  bookingDate    DateTime
  shiftType      ShiftType
  pickupArea     String
  pickupAddress  String?
  seatNumber     String?

  status         ShuttleBookingStatus @default(PENDING)
  remarks        String?

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([employeeId])
  @@index([routeId])
  @@index([pickupStopId])
}

model TransportTrip {
  id                   String        @id @default(uuid())

  routeId              String
  route                TransportRoute @relation(fields: [routeId], references: [id])

  driverId             String
  driver               Driver        @relation(fields: [driverId], references: [id])

  status               TripStatus    @default(CHECKLIST_PENDING)

  fuelChecked          Boolean       @default(false)
  tiresChecked         Boolean       @default(false)
  brakesChecked        Boolean       @default(false)
  lightsChecked        Boolean       @default(false)
  checklistSubmittedAt DateTime?

  startedAt            DateTime?
  endedAt              DateTime?

  issueType            TripIssueType?
  issueDescription     String?
  issueLatitude        Float?
  issueLongitude       Float?
  issueReportedAt      DateTime?

  telemetryLogs VehicleTelemetryLog[]

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([routeId])
  @@index([driverId])
}

model TravelRequest {
  id              String              @id @default(uuid())

  employeeId      String
  employee        User                @relation("EmployeeTravelRequests", fields: [employeeId], references: [id])

  travelType      TravelType
  urgency         TravelUrgency       @default(NORMAL)

  purpose         String
  fromLocation    String
  toLocation      String
  departureDate   DateTime
  returnDate      DateTime?

  accommodationRequired Boolean       @default(false)
  transportRequired     Boolean       @default(false)
  estimatedBudget       Float?

  status          TravelRequestStatus @default(PENDING)

  approvedById    String?
  approvedBy      User?               @relation("TravelRequestApprovals", fields: [approvedById], references: [id])

  decisionRemarks String?
  decidedAt       DateTime?

  employeeRemarks String?

  roomReservation RoomReservation?

  expenseClaims ExpenseClaim[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([employeeId])
  @@index([approvedById])
  @@index([status])
}

model Room {
  id          String     @id @default(uuid())

  roomNumber String     @unique
  roomType   RoomType
  capacity   Int
  location   String
  floor      String?
  status     RoomStatus @default(AVAILABLE)
  notes      String?

  reservations RoomReservation[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model RoomReservation {
  id              String              @id @default(uuid())

  travelRequestId String              @unique
  travelRequest   TravelRequest       @relation(fields: [travelRequestId], references: [id])

  employeeId      String
  employee        User                @relation("EmployeeRoomReservations", fields: [employeeId], references: [id])

  accommodationType AccommodationType @default(INTERNAL_GUEST_HOUSE)

  roomId          String?
  room            Room?               @relation(fields: [roomId], references: [id])

  hotelName       String?
  hotelAddress    String?

  checkInDate     DateTime
  checkOutDate    DateTime

  status          ReservationStatus   @default(CONFIRMED)
  remarks         String?

  checkedInAt     DateTime?
  checkedOutAt    DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([travelRequestId])
  @@index([employeeId])
  @@index([roomId])
}

model ExpenseClaim {
  id              String               @id @default(uuid())

  employeeId      String
  employee        User                 @relation("EmployeeExpenseClaims", fields: [employeeId], references: [id])

  travelRequestId String?
  travelRequest   TravelRequest?       @relation(fields: [travelRequestId], references: [id])

  category        ExpenseCategory
  claimDate       DateTime

  vendorName      String?
  amount          Float
  currency        String               @default("PKR")
  description     String?

  receiptUrl      String?

  ocrVendorName   String?
  ocrDate         String?
  ocrAmount       Float?

  anomalyStatus   ExpenseAnomalyStatus @default(NORMAL)
  anomalyReason   String?

  status          ExpenseClaimStatus   @default(PENDING)

  financeRemarks  String?

  reviewedById    String?
  reviewedBy      User?                @relation("FinanceReviewedExpenseClaims", fields: [reviewedById], references: [id])

  payrollSyncStatus PayrollSyncStatus  @default(NOT_READY)
  exportedAt      DateTime?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([employeeId])
  @@index([travelRequestId])
  @@index([status])
  @@index([anomalyStatus])
}

model AuditLog {
  id              String      @id @default(uuid())

  actorId         String?
  actor           User?       @relation("UserAuditLogs", fields: [actorId], references: [id])

  actorEmail      String?
  actorRole       String?

  action          AuditAction
  entity          AuditEntity
  entityId        String?

  method          String?
  path            String?
  statusCode      Int?

  ipAddress       String?
  userAgent       String?

  requestBody     Json?
  responseMessage String?
  description     String?

  createdAt       DateTime    @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}

model Vendor {
  id              String             @id @default(uuid())

  vendorName      String             @unique
  contactPerson   String?
  phone           String?
  email           String?
  address         String?

  contractType    VendorContractType @default(PER_TRIP)
  status          VendorStatus       @default(ACTIVE)

  contractStartDate DateTime?
  contractEndDate   DateTime?

  notes           String?

  vehicles        Vehicle[]
  routes          TransportRoute[]
  bills           VendorBill[]

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model VendorBill {
  id              String           @id @default(uuid())

  vendorId        String
  vendor          Vendor           @relation(fields: [vendorId], references: [id])

  routeId         String?
  route           TransportRoute?  @relation(fields: [routeId], references: [id])

  billNumber      String           @unique
  billDate        DateTime
  amount          Float
  currency        String           @default("PKR")

  description     String?
  status          VendorBillStatus @default(PENDING)

  financeRemarks  String?
  approvedAt      DateTime?
  paidAt          DateTime?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([vendorId])
  @@index([routeId])
  @@index([status])
}

model VehicleTelemetryLog {
  id              String           @id @default(uuid())

  driverId        String
  driver          Driver           @relation(fields: [driverId], references: [id])

  vehicleId       String?
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id])

  routeId         String?
  route           TransportRoute?  @relation(fields: [routeId], references: [id])

  transportTripId String?
  transportTrip   TransportTrip?   @relation(fields: [transportTripId], references: [id])

  latitude        Float
  longitude       Float
  speed           Float?
  heading         Float?

  status          TelemetryStatus  @default(MOVING)
  source          TelemetrySource  @default(MOBILE_GPS)

  batteryLevel    Int?
  accuracy        Float?
  remarks         String?

  recordedAt      DateTime         @default(now())
  createdAt       DateTime         @default(now())

  @@index([driverId])
  @@index([vehicleId])
  @@index([routeId])
  @@index([transportTripId])
  @@index([status])
  @@index([recordedAt])
}