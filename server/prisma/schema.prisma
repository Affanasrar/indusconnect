
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  EMPLOYEE
  MANAGER
  TRANSPORT_ADMIN
  ACCOMMODATION_ADMIN
  DRIVER
  FINANCE_OFFICER
  SECURITY_OFFICER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum VehicleType {
  BUS
  VAN
  CAR
  COASTER
  HIACE
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum OwnershipType {
  OWNED
  VENDOR
}

enum FitnessStatus {
  VALID
  EXPIRED
  PENDING
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           String     @id @default(uuid())
  fullName     String
  email        String     @unique
  password     String
  phone        String?
  status       UserStatus @default(ACTIVE)

  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Vehicle {
  id            String        @id @default(uuid())
  vehicleNumber String       @unique
  vehicleType   VehicleType
  capacity      Int
  ownershipType OwnershipType @default(OWNED)
  vendorName    String?
  status        VehicleStatus @default(ACTIVE)
  fitnessStatus FitnessStatus @default(PENDING)
  notes         String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}