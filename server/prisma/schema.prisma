
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  EMPLOYEE
  MANAGER
  TRANSPORT_ADMIN
  ACCOMMODATION_ADMIN
  DRIVER
  FINANCE_OFFICER
  SECURITY_OFFICER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum VehicleType {
  BUS
  VAN
  CAR
  COASTER
  HIACE
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum OwnershipType {
  OWNED
  VENDOR
}

enum FitnessStatus {
  VALID
  EXPIRED
  PENDING
}

enum DriverStatus {
  AVAILABLE
  ASSIGNED
  INACTIVE
}

enum RouteStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ShiftType {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
  GENERAL
}

enum ShuttleBookingStatus {
  PENDING
  ASSIGNED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           String     @id @default(uuid())
  fullName     String
  email        String     @unique
  password     String
  phone        String?
  status       UserStatus @default(ACTIVE)

  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])

  driverProfile Driver?
  shuttleBookings ShuttleBooking[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Vehicle {
  id            String        @id @default(uuid())
  vehicleNumber String       @unique
  vehicleType   VehicleType
  capacity      Int
  ownershipType OwnershipType @default(OWNED)
  vendorName    String?
  status        VehicleStatus @default(ACTIVE)
  fitnessStatus FitnessStatus @default(PENDING)
  notes         String?

  drivers Driver[]
  transportRoutes TransportRoute[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Driver {
  id            String       @id @default(uuid())

  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id])

  licenseNumber String       @unique
  cnic          String?
  address       String?
  status        DriverStatus @default(AVAILABLE)

  vehicleId     String?
  vehicle       Vehicle?     @relation(fields: [vehicleId], references: [id])

  transportRoutes TransportRoute[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model TransportRoute {
  id             String       @id @default(uuid())

  routeName      String
  routeCode      String       @unique
  shiftType      ShiftType
  routeDate      DateTime?
  startTime      String?
  endTime        String?
  startLocation  String?
  endLocation    String?

  vehicleId      String?
  vehicle        Vehicle?     @relation(fields: [vehicleId], references: [id])

  driverId       String?
  driver         Driver?      @relation(fields: [driverId], references: [id])

  status         RouteStatus  @default(DRAFT)
  notes          String?

  smartStops     SmartStop[]
  shuttleBookings ShuttleBooking[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SmartStop {
  id             String         @id @default(uuid())

  routeId        String
  route          TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  stopName       String
  stopOrder      Int
  latitude       Float?
  longitude      Float?
  estimatedTime  String?

  shuttleBookings ShuttleBooking[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([routeId, stopOrder])
}

model ShuttleBooking {
  id             String               @id @default(uuid())

  employeeId     String
  employee       User                 @relation(fields: [employeeId], references: [id])

  routeId        String?
  route          TransportRoute?      @relation(fields: [routeId], references: [id])

  pickupStopId   String?
  pickupStop     SmartStop?           @relation(fields: [pickupStopId], references: [id])

  bookingDate    DateTime
  shiftType      ShiftType
  pickupArea     String
  pickupAddress  String?
  seatNumber     String?

  status         ShuttleBookingStatus @default(PENDING)
  remarks        String?

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([employeeId])
  @@index([routeId])
  @@index([pickupStopId])
}