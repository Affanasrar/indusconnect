
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  EMPLOYEE
  MANAGER
  TRANSPORT_ADMIN
  ACCOMMODATION_ADMIN
  DRIVER
  FINANCE_OFFICER
  SECURITY_OFFICER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           String     @id @default(uuid())
  fullName     String
  email        String     @unique
  password     String
  phone        String?
  status       UserStatus @default(ACTIVE)

  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}